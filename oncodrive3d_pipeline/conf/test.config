/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

    Use as follows:
        nextflow run main.nf -profile test --data_dir /path/to/built_datasets/

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    max_cpus   = 4
    max_memory = '20.GB'
    max_time   = '6.h'

    indir = "${baseDir}/../test/input"
    outdir = "${baseDir}/../test/output"
}

process {
    withName: 'ONCODRIVE3D:O3D_RUN' {
        cpus     = 1
        memory   = '4G'
        time     = '2h'
        maxForks = 1
    }

    withName: 'ONCODRIVE3D:O3D_PLOT' {
        cpus   = 1
        memory = '4G'
        time   = '2h'
    }

    withName: 'ONCODRIVE3D:O3D_CHIMERAX_PLOT' {
        cpus   = 1
        memory = '4G'
        time   = '2h'
    }
}